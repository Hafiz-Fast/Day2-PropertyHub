<div class="app-surface app-card transition" data-controller="property-details" aria-expanded="false">
  <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
    <div>
      <h2 class="text-2xl font-semibold">
        <%= property.title %>
      </h2>

      <p class="app-muted mt-2">
        <strong>Owner:</strong>
        <%= property.user.name %>
      </p>

      <p class="app-muted mt-2">
        <strong>Location:</strong>
        <%= property_location(property) %>
      </p>

      <p class="mt-3 text-lg font-bold app-brand">
        <%= formatted_price(property) %>
      </p>
    </div>

    <button type="button" class="app-button" data-action="click->property-details#toggle" data-property-details-target="button">
      <span data-property-details-target="label">View details</span>
    </button>
  </div>

  <div class="app-card-details mt-5 pt-4" hidden data-property-details-target="details">
    <div class="grid gap-3 sm:grid-cols-2">
      <div>
        <p class="text-sm uppercase tracking-[0.18em] app-muted">Bedrooms</p>
        <p class="font-semibold mt-1">
          <%= property.bedrooms.presence || "Not listed" %>
        </p>
      </div>

      <div>
        <p class="text-sm uppercase tracking-[0.18em] app-muted">Published</p>
        <p class="font-semibold mt-1">
          <%= time_ago_in_words(property.created_at) %> ago
        </p>
      </div>
    </div>

    <div class="mt-5 flex flex-wrap items-center gap-3">
      <%= link_to "Open property page", property_path(property), class: "app-link font-semibold" %>
      <span class="app-muted text-sm">Tap the button again to hide these details.</span>
    </div>
  </div>
</div>