<div class="max-w-4xl mx-auto mt-10 px-6">
  <h1 class="text-3xl font-bold mb-6">Users</h1>

  <% if @users.any? %>
    <ul class="space-y-3">
      <% @users.each do |user| %>
        <li class="bg-white p-4 rounded shadow">
          <%= link_to user.name, user_path(user), class: "text-blue-600 font-semibold" %>
          <span class="text-gray-600 ml-3"><%= user.email %></span>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p>No users yet.</p>
  <% end %>
</div>
