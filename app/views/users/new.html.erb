<% content_for :title do %>
  Sign Up
<% end %>

<div class="max-w-md mx-auto mt-24 bg-white p-8 rounded shadow">
  <h1 class="text-2xl font-bold mb-4">Create account</h1>

  <%= form_with model: @user do |f| %>
    <div class="mb-4">
      <%= f.label :name, nil, class: "block mb-1" %>
      <%= f.text_field :name, class: "w-full border rounded p-2" %>
    </div>

    <div class="mb-4">
      <%= f.label :email, nil, class: "block mb-1" %>
      <%= f.email_field :email, class: "w-full border rounded p-2" %>
    </div>

    <div class="mb-6">
      <%= f.label :password, nil, class: "block mb-1" %>
      <%= f.password_field :password, class: "w-full border rounded p-2" %>
    </div>

    <%= f.submit "Sign up", class: "bg-green-600 text-white px-4 py-2 rounded" %>
  <% end %>
</div>
